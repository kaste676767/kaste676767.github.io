    :root {
        --pink: #ff6b9d;
        --pink-light: #ffb3d1;
        --text: #e8e8e8;
    }

    body {
        background: #000000;
        font-family: 'Outfit', sans-serif;
        color: var(--text);
        overflow-x: hidden;
    }

    /* Hero Section */
    .hero {
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    /* Simple Heart Outline */
    .heart-outline {
        position: relative;
        width: 300px;
        height: 300px;
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-20px);
        }
    }

    .heart-outline svg {
        width: 100%;
        height: 100%;
        filter: drop-shadow(0 0 30px var(--pink));
    }

    .heart-outline path {
        stroke: var(--pink);
        stroke-width: 3;
        fill: none;
        animation: draw-heart 2s ease-out forwards;
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
    }

    @keyframes draw-heart {
        to {
            stroke-dashoffset: 0;
        }
    }

    /* Y Letter */
    .letter-y {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: 'DM Serif Display', serif;
        font-size: 120px;
        color: var(--pink);
        opacity: 0;
        animation: fade-in-letter 1s ease-out 1.5s forwards;
    }

    @keyframes fade-in-letter {
        to {
            opacity: 1;
        }
    }

    /* Scroll Indicator */
    .scroll-indicator {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        opacity: 0;
        animation: fade-in-scroll 1s ease-out 2.5s forwards;
    }

    @keyframes fade-in-scroll {
        to {
            opacity: 0.6;
        }
    }

    .scroll-indicator span {
        display: block;
        font-size: 14px;
        color: var(--text);
        margin-bottom: 10px;
        text-align: center;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .arrow {
        width: 2px;
        height: 30px;
        background: var(--pink);
        margin: 0 auto;
        position: relative;
        animation: bounce 2s infinite;
    }

    .arrow::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 0;
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-top: 8px solid var(--pink);
    }

    @keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(10px);
        }
    }

    /* Content Section */
    .content-section {
        min-height: 100vh;
        padding: 100px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .section-title {
        font-family: 'DM Serif Display', serif;
        font-size: 48px;
        color: var(--pink);
        margin-bottom: 80px;
        text-align: center;
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease-out;
    }

    .section-title.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .love-items {
        max-width: 800px;
        width: 100%;
    }

    .love-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 107, 157, 0.2);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 40px;
        opacity: 0;
        transform: translateX(-50px);
        transition: all 0.6s ease-out;
    }

    .love-item:nth-child(even) {
        transform: translateX(50px);
    }

    .love-item.visible {
        opacity: 1;
        transform: translateX(0);
    }

    .love-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 107, 157, 0.4);
        transform: translateY(-5px);
    }

    .item-number {
        font-family: 'DM Serif Display', serif;
        font-size: 24px;
        color: var(--pink);
        margin-bottom: 15px;
    }

    .item-text {
        font-size: 20px;
        line-height: 1.6;
        color: var(--text);
        font-weight: 300;
    }

    .final-message {
        font-family: 'DM Serif Display', serif;
        font-size: 56px;
        color: var(--pink);
        text-align: center;
        margin-top: 100px;
        padding: 60px 20px;
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease-out;
    }

    .final-message.visible {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .heart-outline {
            width: 220px;
            height: 220px;
        }

        .letter-y {
            font-size: 80px;
        }

        .section-title {
